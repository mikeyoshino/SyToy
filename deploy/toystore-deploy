#!/usr/bin/env bash
set -Eeuo pipefail

umask 027

if [[ ${EUID} -ne 0 ]]; then
  echo "toystore-deploy must run as root." >&2
  exit 1
fi

if [[ $# -ne 1 ]]; then
  echo "Expected exactly one immutable GHCR image digest." >&2
  exit 1
fi

next_image="$1"
if [[ ! "$next_image" =~ ^ghcr\.io/[a-z0-9][a-z0-9._/-]*@sha256:[0-9a-f]{64}$ ]]; then
  echo "Expected ghcr.io/owner/image@sha256:<64 lowercase hex characters>." >&2
  exit 1
fi

compose_file=/opt/toystore/compose.production.yaml
compose_env=/etc/toystore/compose.env
state_root=/var/lib/toystore
backup_root=/var/backups/toystore
health_url=http://127.0.0.1:5000/health/ready
runtime_env=""

exec 9>/run/lock/toystore-deploy.lock
if ! flock -n 9; then
  echo "Another Toy Store deployment is already running." >&2
  exit 1
fi

for required_path in "$compose_file" "$compose_env"; do
  if [[ ! -f "$required_path" || -L "$required_path" ]]; then
    echo "Required regular file is missing or unsafe: $required_path" >&2
    exit 1
  fi
done

domain="$(sed -n 's/^TOYSTORE_DOMAIN=//p' "$compose_env")"
if [[ ! "$domain" =~ ^[A-Za-z0-9.-]+$ ]]; then
  echo "TOYSTORE_DOMAIN is missing or invalid in $compose_env." >&2
  exit 1
fi

current_image="$(sed -n 's/^TOYSTORE_IMAGE=//p' "$compose_env")"
if [[ -n "$current_image" ]] \
  && [[ ! "$current_image" =~ ^ghcr\.io/[a-z0-9][a-z0-9._/-]*@sha256:[0-9a-f]{64}$ ]]; then
  echo "Existing TOYSTORE_IMAGE is not an immutable GHCR digest." >&2
  exit 1
fi

install -d -o root -g toystore -m 0750 /opt/toystore /etc/toystore
install -d -o 1654 -g 1654 -m 0750 \
  "$state_root/uploads" "$state_root/keys" "$state_root/logs"
install -d -o toystore -g toystore -m 0750 "$backup_root"

runtime_env="$(mktemp /etc/toystore/.compose.runtime.XXXXXX)"
cleanup() {
  [[ -n "$runtime_env" ]] && rm -f "$runtime_env"
}
trap cleanup EXIT

write_environment() {
  local destination="$1"
  local image="$2"
  printf 'TOYSTORE_DOMAIN=%s\n' "$domain" > "$destination"
  if [[ -n "$image" ]]; then
    printf 'TOYSTORE_IMAGE=%s\n' "$image" >> "$destination"
  fi
  chown root:toystore "$destination"
  chmod 0640 "$destination"
}

write_environment "$runtime_env" "$next_image"

compose() {
  docker compose --env-file "$runtime_env" -f "$compose_file" "$@"
}

compose up -d postgres
for _ in {1..30}; do
  if compose exec -T postgres \
    sh -eu -c 'exec pg_isready --username="$POSTGRES_USER" --dbname="$POSTGRES_DB"' \
    >/dev/null 2>&1; then
    break
  fi
  sleep 2
done
compose exec -T postgres \
  sh -eu -c 'exec pg_isready --username="$POSTGRES_USER" --dbname="$POSTGRES_DB"' \
  >/dev/null

compose pull web caddy postgres

backup_dir=""
deployment_succeeded=false
rollback() {
  local exit_code=$?
  if [[ "$deployment_succeeded" == true ]]; then
    return
  fi

  compose logs --no-color --tail 120 web caddy >&2 || true

  if [[ -n "$current_image" ]]; then
    write_environment "$runtime_env" "$current_image"
    rollback_env="$(mktemp /etc/toystore/.compose.rollback.XXXXXX)"
    write_environment "$rollback_env" "$current_image"
    mv -f "$rollback_env" "$compose_env"
    compose up -d --remove-orphans web caddy || true
    echo "Deployment failed; restored the previous application image." >&2
    if [[ -n "$backup_dir" ]]; then
      echo "Database backup retained at $backup_dir; schema rollback is intentionally manual." >&2
    fi
  else
    rollback_env="$(mktemp /etc/toystore/.compose.rollback.XXXXXX)"
    write_environment "$rollback_env" ""
    mv -f "$rollback_env" "$compose_env"
    compose stop web caddy || true
    echo "Initial deployment failed; no previous application image exists." >&2
  fi

  exit "$exit_code"
}
trap 'rollback' ERR

# Quiesce application writes so the database and committed files form one restore set.
compose stop web

image_digest="${next_image##*@sha256:}"
backup_id="$(date -u +%Y%m%dT%H%M%SZ)-${image_digest:0:12}"
backup_dir="$backup_root/$backup_id"
if ! mkdir "$backup_dir"; then
  echo "Refusing to overwrite existing backup: $backup_dir" >&2
  exit 1
fi
chown toystore:toystore "$backup_dir"
chmod 0750 "$backup_dir"

(
  set -C
  compose exec -T postgres \
    sh -eu -c 'exec pg_dump --format=custom --username="$POSTGRES_USER" --dbname="$POSTGRES_DB"' \
    > "$backup_dir/database.dump"
)

state_paths=()
for state_path in uploads/files keys; do
  if [[ -e "$state_root/$state_path" ]]; then
    state_paths+=("$state_path")
  fi
done

(
  set -C
  tar -C "$state_root" -czf "$backup_dir/files-and-keys.tar.gz" "${state_paths[@]}"
)
chown toystore:toystore "$backup_dir/database.dump" "$backup_dir/files-and-keys.tar.gz"
chmod 0640 "$backup_dir/database.dump" "$backup_dir/files-and-keys.tar.gz"

next_env="$(mktemp /etc/toystore/.compose.next.XXXXXX)"
write_environment "$next_env" "$next_image"
mv -f "$next_env" "$compose_env"

compose up -d --remove-orphans

ready=false
for _ in {1..60}; do
  if curl --fail --silent --show-error "$health_url" >/dev/null; then
    ready=true
    break
  fi
  sleep 2
done

if [[ "$ready" != true ]]; then
  echo "New image did not become ready within 120 seconds." >&2
  false
fi

deployment_succeeded=true
trap - ERR
trap cleanup EXIT

echo "Toy Store image $next_image is ready. Backup: $backup_dir"
