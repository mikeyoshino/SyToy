@using ToyStore.Application.Storefront.Catalog
@implements IAsyncDisposable
@inject CartDrawerCoordinator CartDrawer
@inject IJSRuntime JsRuntime

@if (IsLoading)
{
    <article class="product-card product-card--loading @(SingleColumn ? "product-card--single" : null)" aria-hidden="true">
        <div class="product-card__media product-card__skeleton"></div>
        <div class="product-card__body">
            <span class="product-card__skeleton product-card__skeleton--short"></span>
            <span class="product-card__skeleton"></span>
            <span class="product-card__skeleton product-card__skeleton--price"></span>
        </div>
    </article>
    <span class="visually-hidden" role="status">กำลังโหลดสินค้า</span>
}
else
{
    <article class="product-card @(SingleColumn ? "product-card--single" : null)">
        <div @ref="mediaElement" class="product-card__media">
            <a class="product-card__media-link" href="@Model.ProductUrl" aria-label="ดูรายละเอียด @Model.Name โดย @Model.Brand">
                @if (CurrentImage is not null)
                {
                    <img @key="CurrentImage.Url" src="@CurrentImage.Url" alt="@CurrentImage.AltText"
                         loading="lazy" decoding="async" />
                }
                else
                {
                    <span class="product-card__placeholder" aria-hidden="true"><i></i></span>
                }
            </a>
            <div class="product-card__badges">
                <span class="product-card__badge">@Model.TypeLabel</span>
                @if (!string.IsNullOrWhiteSpace(Model.ModelScale))
                {
                    <span class="product-card__badge product-card__badge--scale">สเกล @Model.ModelScale</span>
                }
            </div>
            @if (ImageCount > 1)
            {
                <button class="product-card__gallery-button product-card__gallery-button--previous" type="button"
                        @onclick="PreviousImage" aria-label="ดูรูปก่อนหน้าของ @Model.Name">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7" /></svg>
                </button>
                <button class="product-card__gallery-button product-card__gallery-button--next" type="button"
                        @onclick="NextImage" aria-label="ดูรูปถัดไปของ @Model.Name">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7" /></svg>
                </button>
                <span class="visually-hidden" aria-live="polite">รูปที่ @(currentImageIndex + 1) จาก @ImageCount</span>
            }
        </div>
        <a class="product-card__detail" href="@Model.ProductUrl" aria-label="ดูรายละเอียด @Model.Name โดย @Model.Brand">
            <div class="product-card__body">
                <h3>@Model.Name</h3>
                <p>@Model.Brand</p>
                <strong>@Model.PriceLabel</strong>
            </div>
        </a>
        @if (Model.SaleType == StorefrontSaleType.InStock && Model.OfferState == StorefrontOfferState.InStockAvailable)
        {
            <button class="product-card__action touch-target" type="button" disabled="@isAdding"
                    @onclick="AddAsync" aria-label="เพิ่ม @Model.Name ลงตะกร้า">
                @(isAdding ? "กำลังเพิ่ม…" : "เพิ่มลงตะกร้า") <span aria-hidden="true">+</span>
            </button>
        }
        else if (Model.SaleType == StorefrontSaleType.InStock)
        {
            <button class="product-card__action product-card__action--disabled" type="button" disabled aria-label="@Model.Name สินค้าหมดชั่วคราว">
                สินค้าหมดชั่วคราว
            </button>
        }
        else if (Model.OfferState == StorefrontOfferState.PreOrderOpen)
        {
            <a class="product-card__action product-card__action--preorder touch-target"
               href="@Model.ProductUrl" aria-label="ดูรายละเอียดพรีออเดอร์ @Model.Name">
                ดูรายละเอียดพรีออเดอร์
            </a>
        }
        else
        {
            <span class="product-card__action product-card__action--disabled" aria-disabled="true">
                @(Model.OfferState == StorefrontOfferState.PreOrderFull ? "พรีออเดอร์เต็มแล้ว" : "ปิดรับพรีออเดอร์แล้ว")
            </span>
        }
    </article>
}

@code {
    private static readonly ProductCardModel LoadingModel = new(
        Guid.Empty,
        string.Empty,
        string.Empty,
        string.Empty,
        string.Empty,
        null,
        string.Empty,
        StorefrontSaleType.InStock,
        StorefrontOfferState.InStockOutOfStock);

    [Parameter]
    public ProductCardModel Model { get; set; } = LoadingModel;

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool SingleColumn { get; set; }

    private bool isAdding;
    private bool swipeInitialized;
    private bool disposed;
    private Guid currentProductId;
    private int currentImageIndex;
    private ElementReference mediaElement;
    private IJSObjectReference? swipeModule;
    private DotNetObjectReference<ProductCard>? dotNetReference;
    private IReadOnlyList<ProductCardImageModel> GalleryImages => Model.GalleryImages;
    private int ImageCount => GalleryImages.Count;
    private ProductCardImageModel? CurrentImage => ImageCount == 0
        ? null
        : GalleryImages[Math.Clamp(currentImageIndex, 0, ImageCount - 1)];

    protected override void OnParametersSet()
    {
        if (currentProductId == Model.ProductId && currentImageIndex < ImageCount) return;
        currentProductId = Model.ProductId;
        currentImageIndex = 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (disposed || IsLoading || ImageCount <= 1 || swipeInitialized)
        {
            return;
        }

        try
        {
            swipeModule ??= await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "./Components/Storefront/ProductCard.razor.js");
            dotNetReference ??= DotNetObjectReference.Create(this);
            await swipeModule.InvokeVoidAsync("initialize", mediaElement, dotNetReference);
            swipeInitialized = true;
        }
        catch (InvalidOperationException)
        {
            // JavaScript interop is unavailable during static prerendering.
        }
        catch (JSDisconnectedException)
        {
            // The circuit can disconnect while the card is hydrating.
        }
    }

    private void PreviousImage() => currentImageIndex = ImageCount == 0
        ? 0
        : (currentImageIndex - 1 + ImageCount) % ImageCount;

    private void NextImage() => currentImageIndex = ImageCount == 0
        ? 0
        : (currentImageIndex + 1) % ImageCount;

    [JSInvokable]
    public Task ShowPreviousImageFromSwipeAsync()
    {
        PreviousImage();
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task ShowNextImageFromSwipeAsync()
    {
        NextImage();
        return InvokeAsync(StateHasChanged);
    }

    private async Task AddAsync()
    {
        if (isAdding || Model.ProductId == Guid.Empty || Model.SaleType != StorefrontSaleType.InStock
            || Model.OfferState != StorefrontOfferState.InStockAvailable) return;
        isAdding = true;
        try { await CartDrawer.AddProductAsync(Model.ProductId); }
        finally { isAdding = false; }
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        dotNetReference?.Dispose();
        if (swipeModule is null)
        {
            return;
        }

        try
        {
            if (swipeInitialized)
            {
                await swipeModule.InvokeVoidAsync("dispose", mediaElement);
            }
            await swipeModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }
}
