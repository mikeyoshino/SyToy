<button type="@ButtonType"
        form="@Form"
        class="@CssClasses"
        disabled="@IsEffectivelyDisabled"
        aria-busy="@(IsBusy ? "true" : null)"
        @attributes="AdditionalAttributes"
        @onclick="OnClick">
    @if (IsBusy)
    {
        <span class="store-action__spinner" aria-hidden="true"></span>
        <span>@(LoadingText ?? "กำลังดำเนินการ…")</span>
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [CascadingParameter]
    private StoreButtonGroup? ButtonGroup { get; set; }

    [Parameter]
    public string ButtonType { get; set; } = "button";

    [Parameter]
    public string? Form { get; set; }

    [Parameter]
    public StoreButtonTone Tone { get; set; } = StoreButtonTone.Primary;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string? LoadingText { get; set; }

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public bool FullWidth { get; set; }

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsEffectivelyDisabled => Disabled || IsBusy || ButtonGroup?.IsBusy == true;

    private string CssClasses => string.Join(
        ' ',
        new[]
        {
            "store-action",
            $"store-action--{Tone.ToString().ToLowerInvariant()}",
            FullWidth ? "store-action--full" : null,
            Compact ? "store-action--compact" : null,
            CssClass,
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
