@using System.Linq.Expressions

<StoreFieldShell FieldId="@FieldId"
                 Label="@Label"
                 HelpText="@HelpText"
                 Required="@Required">
    <ChildContent>
        @if (IsPassword)
        {
            <div class="store-password">
                @if (UpdateOnInput)
                {
                    <input value="@Value"
                           @attributes="ControlAttributes"
                           @oninput="HandleInputAsync" />
                }
                else
                {
                    <InputText Value="@Value"
                               ValueChanged="@ValueChanged"
                               ValueExpression="@ValueExpression"
                               @attributes="ControlAttributes" />
                }
                <button type="button"
                        class="store-password__toggle touch-target"
                        data-password-toggle
                        data-password-input="@FieldId"
                        aria-controls="@FieldId"
                        aria-pressed="false"
                        aria-label="แสดงรหัสผ่าน"
                        disabled="@Disabled">
                    <svg class="store-password__icon store-password__icon--show" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                        <circle cx="12" cy="12" r="2.75" />
                    </svg>
                    <svg class="store-password__icon store-password__icon--hide" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 4 20 20M9.7 6.35A9.7 9.7 0 0 1 12 6c6 0 9.5 6 9.5 6a15 15 0 0 1-2.2 2.8M6.3 7.7C3.8 9.45 2.5 12 2.5 12s3.5 6 9.5 6c1 0 1.95-.16 2.8-.45M9.9 9.9a3 3 0 0 0 4.2 4.2" />
                    </svg>
                </button>
            </div>
        }
        else if (UpdateOnInput)
        {
            <input value="@Value"
                   @attributes="ControlAttributes"
                   @oninput="HandleInputAsync" />
        }
        else
        {
            <InputText Value="@Value"
                       ValueChanged="@ValueChanged"
                       ValueExpression="@ValueExpression"
                       @attributes="ControlAttributes" />
        }
    </ChildContent>
    <ErrorContent>
        @if (EditContext is not null)
        {
            <ValidationMessage For="@ValueExpression" />
        }
    </ErrorContent>
</StoreFieldShell>

@code {
    private readonly string generatedId = $"store-field-{Guid.NewGuid():N}";

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter, EditorRequired]
    public required string Label { get; set; }

    [Parameter]
    public string? HelpText { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Type { get; set; } = "text";

    [Parameter]
    public string? Autocomplete { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool UpdateOnInput { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter, EditorRequired]
    public Expression<Func<string?>> ValueExpression { get; set; } = default!;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string FieldId => Id ?? IdFromAttributes ?? generatedId;

    private bool IsPassword => string.Equals(Type, "password", StringComparison.OrdinalIgnoreCase);

    private string? IdFromAttributes => AdditionalAttributes is not null
        && AdditionalAttributes.TryGetValue("id", out var id)
            ? Convert.ToString(id, System.Globalization.CultureInfo.InvariantCulture)
            : null;

    private bool IsInvalid => EditContext is not null
        && ValueExpression is not null
        && EditContext.GetValidationMessages(FieldIdentifier.Create(ValueExpression)).Any();

    private string DescribedBy => string.IsNullOrWhiteSpace(HelpText)
        ? $"{FieldId}-error"
        : $"{FieldId}-help {FieldId}-error";

    private Dictionary<string, object> ControlAttributes => FieldAttributeBuilder.Create(
        AdditionalAttributes,
        FieldId,
        "store-field__control",
        Required,
        Disabled,
        IsInvalid,
        DescribedBy,
        ("type", Type),
        ("autocomplete", Autocomplete),
        ("placeholder", Placeholder));

    private async Task HandleInputAsync(ChangeEventArgs args)
    {
        Value = Convert.ToString(args.Value, System.Globalization.CultureInfo.CurrentCulture);
        await ValueChanged.InvokeAsync(Value);
        if (EditContext is not null && ValueExpression is not null)
        {
            EditContext.NotifyFieldChanged(FieldIdentifier.Create(ValueExpression));
        }
    }
}
