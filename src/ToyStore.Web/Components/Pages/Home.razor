@page "/"
@using System.Globalization
@using MediatR
@using ToyStore.Application.Storefront.Catalog
@using ToyStore.Web.Components.Storefront.Models
@inject ISender Sender
@inject ILogger<Home> Logger
@inject NavigationManager NavigationManager

<StorefrontSeoMetadata Title="@HomeTitle"
                       Description="@HomeDescription"
                       CanonicalUrl="@CanonicalUrl"
                       ImageUrl="@SocialImageUrl"
                       ImageAlt="@SocialImageAlt"
                       StructuredDataJson="@HomeStructuredData" />

<div class="home store-container">
    <HeroShowcase Products="@preOrderProducts" State="@preOrderState" OnRetry="LoadFeaturedAsync" />

    <section class="home__section" aria-labelledby="featured-products-title">
        <SectionHeader
            Title="สินค้าแนะนำ"
            HeadingId="featured-products-title"
            ActionLabel="ดูทั้งหมด"
            ActionUrl="/products" />
        <ProductGallery Products="@featuredProducts" State="@featuredState" OnRetry="LoadFeaturedAsync"
                        LoadingCardCount="8" />
    </section>

    <section class="home__section" aria-labelledby="collections-title">
        <SectionHeader
            Title="คอลเลกชันที่น่าสำรวจ"
            HeadingId="collections-title"
            ActionLabel="สำรวจทั้งหมด"
            ActionUrl="/products" />
        <div class="home__collections">
            @foreach (var collection in collections)
            {
                <CollectionCard @key="collection" Model="collection" />
            }
        </div>
    </section>

    <div class="home__section">
        <JournalFeature Heading="เรื่องเล่าจากโลกของเล่น"
                        Summary="ไอเดียเลือกและจัดแสดงของเล่นให้สนุกในทุกพื้นที่"
                        AllStoriesUrl="/products"
                        Stories="@JournalStories" />
    </div>

    <div class="home__section home__section--trust">
        <TrustBenefits />
    </div>
</div>

@code {
    private static readonly CultureInfo ThaiCulture = CultureInfo.GetCultureInfo("th-TH");
    private const string HomeTitle = "SY TOY | อาร์ตทอยและกันดั้ม พร้อมส่งและพรีออเดอร์";
    private const string HomeDescription = "เลือกซื้ออาร์ตทอยและกันดั้มจาก SY TOY ทั้งสินค้าพร้อมส่งและพรีออเดอร์ พร้อมราคา สถานะสินค้า การชำระเงินปลอดภัย และจัดส่งพร้อมเลขติดตาม";
    private IReadOnlyList<ProductCardModel> featuredProducts = [];
    private IReadOnlyList<ProductCardModel> preOrderProducts = [];
    private IReadOnlyList<CollectionCardModel> collections = [];
    private static readonly IReadOnlyList<JournalStoryModel> JournalStories =
    [
        new("เลือกอาร์ตทอยชิ้นแรกอย่างไรให้ตรงใจ", "12 กรกฎาคม 2026", "2026-07-12", "/products"),
        new("จากเส้นร่างสู่คาแรกเตอร์บนชั้นสะสม", "28 มิถุนายน 2026", "2026-06-28", "/products"),
        new("จัดมุมแสดงของเล่นให้สนุกและดูแลง่าย", "9 มิถุนายน 2026", "2026-06-09", "/products"),
    ];
    private StorefrontContentState featuredState = StorefrontContentState.Loading;
    private StorefrontContentState preOrderState = StorefrontContentState.Loading;
    private string CanonicalUrl => NavigationManager.ToAbsoluteUri("/").ToString();
    private ProductCardModel? SocialProduct => preOrderProducts
        .Concat(featuredProducts)
        .FirstOrDefault(product => !string.IsNullOrWhiteSpace(product.ImageUrl));
    private string? SocialImageUrl => SocialProduct?.ImageUrl is { } imageUrl
        ? NavigationManager.ToAbsoluteUri(imageUrl).ToString()
        : NavigationManager.ToAbsoluteUri("/images/brand/sy-toys-mark-v2.png").ToString();
    private string SocialImageAlt => SocialProduct is null
        ? "โลโก้ SY TOYS"
        : $"{SocialProduct.Name} {SocialProduct.Brand}";
    private string HomeStructuredData => StorefrontStructuredData.BuildHome(
        new Uri(CanonicalUrl),
        NavigationManager.ToAbsoluteUri("/images/brand/sy-toys-mark-v2.png"),
        SocialImageUrl is null ? null : new Uri(SocialImageUrl),
        HomeDescription);

    protected override Task OnInitializedAsync() => LoadFeaturedAsync();

    private async Task LoadFeaturedAsync()
    {
        featuredState = StorefrontContentState.Loading;
        preOrderState = StorefrontContentState.Loading;
        try
        {
            var featuredTask = Sender.Send(new ListStorefrontProductsQuery(
                SaleType: StorefrontSaleTypeFilter.All,
                PageSize: 8));
            var preOrderTask = Sender.Send(new ListStorefrontProductsQuery(
                SaleType: StorefrontSaleTypeFilter.PreOrder,
                PageSize: 5));
            await Task.WhenAll(featuredTask, preOrderTask);

            var featuredResult = await featuredTask;
            var preOrderResult = await preOrderTask;
            if (featuredResult.IsFailure)
            {
                featuredState = StorefrontContentState.Error;
            }
            else
            {
                featuredProducts = featuredResult.Value.Items
                    .Select(item => ProductCardModel.From(item, ThaiCulture))
                    .ToArray();
                collections = featuredResult.Value.Categories.Select(option => new CollectionCardModel(
                    option.Label, $"เลือกดู{option.Label}พร้อมส่ง", $"/products?category={option.Id:D}")).ToArray();
                featuredState = featuredProducts.Count == 0
                    ? StorefrontContentState.Empty
                    : StorefrontContentState.Normal;
            }

            if (preOrderResult.IsFailure)
            {
                preOrderState = StorefrontContentState.Error;
            }
            else
            {
                preOrderProducts = preOrderResult.Value.Items
                    .Where(item => item.SaleType == StorefrontSaleType.PreOrder)
                    .Take(5)
                    .Select(item => ProductCardModel.From(item, ThaiCulture))
                    .ToArray();
                preOrderState = preOrderProducts.Count == 0
                    ? StorefrontContentState.Empty
                    : StorefrontContentState.Normal;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Storefront home catalog query failed.");
            featuredState = StorefrontContentState.Error;
            preOrderState = StorefrontContentState.Error;
        }
    }
}
