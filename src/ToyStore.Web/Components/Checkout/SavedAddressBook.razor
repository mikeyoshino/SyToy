@using MediatR
@using ToyStore.Application.Addresses.SavedAddresses
@using ToyStore.Application.Addresses.SavedAddresses.CreateSavedAddress
@using ToyStore.Application.Addresses.SavedAddresses.DeleteSavedAddress
@using ToyStore.Application.Addresses.SavedAddresses.ListSavedAddresses
@using ToyStore.Application.Addresses.SavedAddresses.SetDefaultSavedAddress
@inject ISender Sender

<section class="saved-address-book" aria-labelledby="saved-address-title">
    <div class="saved-address-book__heading">
        <div>
            <h2 id="saved-address-title">ที่อยู่ที่บันทึกไว้</h2>
            <p>เลือกใช้ได้ทันที และบันทึกได้สูงสุด 5 ที่อยู่</p>
        </div>
        <span aria-label="บันทึกแล้ว @addresses.Count จาก 5 ที่อยู่">@addresses.Count/5</span>
    </div>

    @if (isLoading)
    {
        <p class="saved-address-book__state" role="status">กำลังโหลดที่อยู่…</p>
    }
    else if (addresses.Count != 0)
    {
        <div class="saved-address-book__list" role="list">
            @foreach (var item in addresses)
            {
                <article class="saved-address-book__card @(selectedAddressId == item.Id ? "saved-address-book__card--selected" : null)" role="listitem">
                    <button type="button" class="saved-address-book__select"
                            disabled="@(Disabled || isMutating)" @onclick="() => ApplyAsync(item)"
                            aria-pressed="@(selectedAddressId == item.Id)"
                            aria-label="ใช้ที่อยู่ @item.Label">
                        <span class="saved-address-book__label">
                            <strong>@item.Label</strong>
                            @if (item.IsDefault) { <small>ค่าเริ่มต้น</small> }
                        </span>
                        <span>@item.RecipientName · @item.PhoneNumber</span>
                        <span>@FormatAddress(item)</span>
                    </button>
                    <div class="saved-address-book__actions">
                        @if (!item.IsDefault)
                        {
                            <button type="button" disabled="@(Disabled || isMutating)"
                                    @onclick="() => SetDefaultAsync(item.Id)">ตั้งเป็นค่าเริ่มต้น</button>
                        }
                        <button type="button" disabled="@(Disabled || isMutating)"
                                @onclick="() => DeleteAsync(item.Id)" aria-label="ลบที่อยู่ @item.Label">ลบ</button>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <p class="saved-address-book__state">ยังไม่มีที่อยู่ที่บันทึกไว้ กรอกแบบฟอร์มด้านล่างแล้วกดบันทึกได้เลย</p>
    }

    @if (!string.IsNullOrWhiteSpace(feedback))
    {
        <p class="saved-address-book__feedback @(hasError ? "saved-address-book__feedback--error" : null)"
           role="@(hasError ? "alert" : "status")">@feedback</p>
    }

    <div class="saved-address-book__save">
        <StoreTextField @bind-Value="label" Label="ชื่อเรียกที่อยู่นี้"
                        Placeholder="เช่น บ้าน, ที่ทำงาน" Disabled="@(Disabled || isMutating || addresses.Count >= 5)" />
        <label class="saved-address-book__default">
            <input type="checkbox" @bind="makeDefault" disabled="@(Disabled || isMutating || addresses.Count >= 5)" />
            <span>ใช้เป็นที่อยู่เริ่มต้น</span>
        </label>
        <StoreButton OnClick="SaveAsync" Tone="StoreButtonTone.Secondary" Compact="true"
                     Disabled="@(Disabled || isMutating || addresses.Count >= 5)"
                     IsBusy="@isMutating" LoadingText="กำลังบันทึก…">
            บันทึกที่อยู่นี้
        </StoreButton>
    </div>
</section>

@code {
    private IReadOnlyList<SavedAddressView> addresses = [];
    private Guid? selectedAddressId;
    private string? label;
    private string? feedback;
    private bool makeDefault;
    private bool isLoading = true;
    private bool isMutating;
    private bool hasError;

    [Parameter, EditorRequired] public required ShippingAddressFormModel Model { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback AddressApplied { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        isLoading = false;
        var defaultAddress = addresses.FirstOrDefault(item => item.IsDefault);
        if (defaultAddress is not null && IsEmpty(Model)) await ApplyAsync(defaultAddress);
    }

    private async Task ReloadAsync()
    {
        var result = await Sender.Send(new ListSavedAddressesQuery());
        if (result.IsSuccess) addresses = result.Value;
        else SetFeedback(result.Error.Message, true);
    }

    private async Task ApplyAsync(SavedAddressView item)
    {
        selectedAddressId = item.Id;
        Model.RecipientName = item.RecipientName;
        Model.PhoneNumber = item.PhoneNumber;
        Model.AddressLine = item.AddressLine;
        Model.ProvinceId = item.ProvinceId;
        Model.DistrictId = item.DistrictId;
        Model.SubDistrictId = item.SubDistrictId;
        Model.Province = item.Province;
        Model.District = item.District;
        Model.SubDistrict = item.SubDistrict;
        Model.PostalCode = item.PostalCode;
        SetFeedback($"เลือกที่อยู่ {item.Label} แล้ว", false);
        await AddressApplied.InvokeAsync();
    }

    private async Task SaveAsync()
    {
        if (isMutating) return;
        isMutating = true;
        SetFeedback(null, false);
        try
        {
            var result = await Sender.Send(new CreateSavedAddressCommand(label ?? "",
                Model.RecipientName ?? "", Model.PhoneNumber ?? "", Model.AddressLine ?? "",
                Model.ProvinceId ?? 0, Model.DistrictId ?? 0, Model.SubDistrictId ?? 0,
                Model.Province ?? "", Model.District ?? "", Model.SubDistrict ?? "",
                Model.PostalCode ?? "", makeDefault));
            if (!result.IsSuccess)
            {
                SetFeedback(result.ValidationFailures.Select(x => x.ErrorMessage)
                    .FirstOrDefault() ?? result.Error.Message, true);
                return;
            }
            label = null;
            makeDefault = false;
            selectedAddressId = result.Value.Id;
            await ReloadAsync();
            SetFeedback("บันทึกที่อยู่เรียบร้อย", false);
        }
        finally { isMutating = false; }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (isMutating) return;
        isMutating = true;
        try
        {
            var result = await Sender.Send(new DeleteSavedAddressCommand(id));
            if (!result.IsSuccess) { SetFeedback(result.Error.Message, true); return; }
            if (selectedAddressId == id) selectedAddressId = null;
            await ReloadAsync();
            SetFeedback("ลบที่อยู่ที่บันทึกแล้ว", false);
        }
        finally { isMutating = false; }
    }

    private async Task SetDefaultAsync(Guid id)
    {
        if (isMutating) return;
        isMutating = true;
        try
        {
            var result = await Sender.Send(new SetDefaultSavedAddressCommand(id));
            if (!result.IsSuccess) { SetFeedback(result.Error.Message, true); return; }
            await ReloadAsync();
            SetFeedback("ตั้งเป็นที่อยู่เริ่มต้นแล้ว", false);
        }
        finally { isMutating = false; }
    }

    private void SetFeedback(string? message, bool error)
    {
        feedback = message;
        hasError = error;
    }

    private static bool IsEmpty(ShippingAddressFormModel model) =>
        string.IsNullOrWhiteSpace(model.RecipientName) && string.IsNullOrWhiteSpace(model.AddressLine);

    private static string FormatAddress(SavedAddressView item) =>
        $"{item.AddressLine} {item.SubDistrict} {item.District} {item.Province} {item.PostalCode}";
}
