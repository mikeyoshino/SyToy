@page "/Account/Manage/ChangePassword"

@using System.ComponentModel.DataAnnotations
@using MediatR
@using ToyStore.Application.Accounts.ChangePassword

@inject ISender Sender
@inject IdentityRedirectManager RedirectManager

<PageTitle>เปลี่ยนรหัสผ่าน</PageTitle>

<section class="account-page account-page--manage" aria-labelledby="change-password-heading">
    <h1 id="change-password-heading">เปลี่ยนรหัสผ่าน</h1>
    <p>กรอกรหัสผ่านปัจจุบันและตั้งรหัสผ่านใหม่สำหรับบัญชีของคุณ</p>
    <StatusMessage Message="@message" />

    <EditForm EditContext="editContext" FormName="change-password" OnValidSubmit="ChangePasswordAsync" method="post" class="account-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="store-validation-summary" role="alert" />

        <StoreTextField @bind-Value="Input.CurrentPassword"
                        Id="current-password"
                        Label="รหัสผ่านปัจจุบัน"
                        Required="true"
                        Type="password"
                        Autocomplete="current-password"
                        Placeholder="รหัสผ่านปัจจุบัน" />
        <StoreTextField @bind-Value="Input.NewPassword"
                        Id="new-password"
                        Label="รหัสผ่านใหม่"
                        Required="true"
                        Type="password"
                        Autocomplete="new-password"
                        Placeholder="รหัสผ่านใหม่" />
        <StoreTextField @bind-Value="Input.ConfirmPassword"
                        Id="confirm-new-password"
                        Label="ยืนยันรหัสผ่านใหม่"
                        Required="true"
                        Type="password"
                        Autocomplete="new-password"
                        Placeholder="ยืนยันรหัสผ่านใหม่" />

        <StoreButton ButtonType="submit">บันทึกรหัสผ่านใหม่</StoreButton>
    </EditForm>
</section>

@code {
    private string? message;
    private EditContext editContext = default!;
    private FormValidationStore validationStore = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override void OnInitialized()
    {
        Input ??= new();
        editContext = new EditContext(Input);
        validationStore = new FormValidationStore(editContext);
    }

    private async Task ChangePasswordAsync()
    {
        message = null;
        validationStore.Clear();

        var result = await Sender.Send(
            new ChangePasswordCommand(
                Input.CurrentPassword,
                Input.NewPassword,
                Input.ConfirmPassword),
            HttpContext.RequestAborted);

        if (result.IsFailure)
        {
            if (result.ValidationFailures.Count != 0)
            {
                validationStore.Display(result.ValidationFailures);
            }
            else
            {
                message = $"ข้อผิดพลาด: {result.Error.Message}";
            }

            return;
        }

        RedirectManager.RedirectToCurrentPageWithStatus(
            "เปลี่ยนรหัสผ่านเรียบร้อยแล้ว",
            HttpContext);
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "กรุณากรอกรหัสผ่านปัจจุบัน")]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "กรุณากรอกรหัสผ่านใหม่")]
        [StringLength(100, MinimumLength = 8, ErrorMessage = "รหัสผ่านใหม่ต้องมีความยาว 8–100 ตัวอักษร")]
        [RegularExpression(
            "^(?=.*[A-Z])(?=.*[a-z])(?=.*[0-9]).+$",
            ErrorMessage = "รหัสผ่านใหม่ต้องมีตัวอักษรภาษาอังกฤษพิมพ์ใหญ่ พิมพ์เล็ก และตัวเลขอย่างน้อยอย่างละ 1 ตัว")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "กรุณายืนยันรหัสผ่านใหม่")]
        [Compare(nameof(NewPassword), ErrorMessage = "รหัสผ่านและการยืนยันรหัสผ่านไม่ตรงกัน")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
